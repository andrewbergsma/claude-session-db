# claude-session-db — local configuration
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit it.

# The claude_sessions archive DSN. Takes precedence over everything else.
# CSD_DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/claude_sessions

# Fallback: a DSN pointing at the sibling `knowledge` DB on the same host.
# csd swaps the database name to `claude_sessions` automatically.
# DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/knowledge

# Optional: explicit DSN for the kmcp `knowledge` DB used by `csd reconcile`.
# Defaults to the resolved archive DSN with the db name swapped to `knowledge`.
# KMCP_DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/knowledge
